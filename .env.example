# Firebase web app config — copy to .env for local dev, and add the same
# variables in Vercel (Project Settings → Environment Variables) for production.
# All values come from Firebase Console → Project settings → Your apps → Web app.
# These are safe to expose in the client bundle; security lives in firestore.rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only needed if Google Analytics is enabled for the Firebase web
# app. Firebase Console → Project settings → Your apps → Web app → this is
# the "Measurement ID" (starts with G-). Leave blank to skip Analytics.
VITE_FIREBASE_MEASUREMENT_ID=
