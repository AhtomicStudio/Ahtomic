rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Site content: the public doc is world-readable; the draft is admin-only.
    // Any signed-in user is an admin — only create accounts for yourself.
    match /site-content/public {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /site-content/draft {
      allow read, write: if request.auth != null;
    }

    // Contact form: anyone may submit (with basic shape/size checks),
    // but only the admin can read, and nobody can edit or delete from the client.
    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() < 200
                    && request.resource.data.email.matches('.*@.*')
                    && request.resource.data.name is string
                    && request.resource.data.name.size() < 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() < 5000;
      allow read: if request.auth != null;
      // Deletable by the admin (e.g. clearing spam/test entries from the
      // dashboard); update stays blocked since a reply is a separate email,
      // never a mutation of the original submission.
      allow delete: if request.auth != null;
      allow update: if false;
    }

    // Everything else is locked.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
